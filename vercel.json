{
  "version": 2,
  "fluid": false,
  "functions": {
    "api/submit.js": {
      "maxDuration": 30,
      "includeFiles": "node_modules/@resvg/resvg-wasm/**,node_modules/@pdf-lib/fontkit/**,fonts/DejaVuSans.ttf"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
}
{
  "version": 2,
  "functions": {
    "api/submit.mjs": {
      "runtime": "nodejs20.x",
      "maxDuration": 30,
      "includeFiles": "node_modules/@resvg/resvg-wasm/**,fonts/DejaVuSans.ttf"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
}